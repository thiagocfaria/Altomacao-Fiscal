# Certificados e segredos
*.pfx
*.p12
*.pem
*.key
*.crt
*.cer
*.senha
*.secret
secrets/

# Arquivos fiscais e operacionais importados
*.xml
*.pdf
*.zip
*.gz

# Backend tecnico local
backend/ledger/*
backend/logs/*
backend/fila/*
backend/quarentena/*
backend/health/*

# Config local sensivel
operacao/config/*.local.*

!.gitignore
!.gitkeep
!pom.xml
!src/main/resources/logback.xml
!src/test/resources/logback-test.xml
!backend/ledger/.gitkeep
!backend/logs/.gitkeep
!backend/fila/.gitkeep
!backend/quarentena/.gitkeep
!backend/health/.gitkeep
!operacao/certificados/.gitkeep
!operacao/config/.gitkeep
